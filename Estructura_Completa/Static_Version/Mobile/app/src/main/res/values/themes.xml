<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Static_Version" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_orange</item>
        <item name="colorPrimaryVariant">@color/bg_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="android:windowBackground">@color/bg_dark</item>

        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>
    <style name="CalendarDay">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">12sp</item>
        <item name="android:background">@drawable/input_style</item>
        <item name="android:backgroundTint">#1D1B26</item>
    </style>
</resources>