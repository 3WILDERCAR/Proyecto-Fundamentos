<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estadísticas"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="25dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/card_style"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRODUCTIVIDAD SEMANAL"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:layout_marginBottom="15dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0D0F14">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/accent_purple"
                    android:layout_gravity="bottom" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_style"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BALANCE ESTUDIO / DESCANSO"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:layout_marginBottom="15dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="6dp">
                    <View android:layout_width="25dp" android:layout_height="100dp" android:background="@color/accent_purple" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M" android:textColor="@color/text_dim" android:textSize="10sp" android:layout_marginTop="5dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="6dp">
                    <View android:layout_width="25dp" android:layout_height="45dp" android:background="#55EFC4" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="J" android:textColor="@color/text_dim" android:textSize="10sp" android:layout_marginTop="5dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="6dp">
                    <View android:layout_width="25dp" android:layout_height="65dp" android:background="#FF7675" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mi" android:textColor="@color/text_dim" android:textSize="10sp" android:layout_marginTop="5dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="6dp">
                    <View android:layout_width="25dp" android:layout_height="85dp" android:background="#FFE66D" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="J" android:textColor="@color/text_dim" android:textSize="10sp" android:layout_marginTop="5dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="6dp">
                    <View android:layout_width="25dp" android:layout_height="110dp" android:background="#55EFC4" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="V" android:textColor="@color/text_dim" android:textSize="10sp" android:layout_marginTop="5dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_style"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESTADO EMOCIONAL"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:layout_marginBottom="15dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_margin="10dp"
                    android:background="@drawable/card_style"
                    android:backgroundTint="#55EFC4" />

                <View
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_margin="10dp"
                    android:background="@drawable/card_style"
                    android:backgroundTint="@color/accent_purple" />

                <View
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_margin="10dp"
                    android:background="@drawable/card_style"
                    android:backgroundTint="#FF7675" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_style"
            android:backgroundTint="#1D1B26"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/accent_purple"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="IA Gemini"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingMultiplier="1.2"
                android:text='"Según tus estadísticas, has avanzado bien en los conceptos básicos de Android. Sin embargo, aún puedes reforzar temas como la navegación entre pantallas y el uso de layouts." 🎯'
                android:textColor="@color/text_dim"
                android:textSize="13sp"
                android:fontStyle="italic" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>